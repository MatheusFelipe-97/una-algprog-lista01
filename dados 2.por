programa {
  cadeia cidademora
  cadeia cidadeestuda
  
  funcao inicio() {
    escreva("Informe a cidade onde você mora:")
    leia(cidademora)

    escreva("A cidade onde você mora é: " + cidademora)

    escreva("\n Informe a cidade onde você estuda:")
    leia(cidadeestuda)

    escreva("\n A cidade onde você estuda é: " + cidadeestuda)
  }
}
